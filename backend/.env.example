# FinanceMe — Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Required ────────────────────────────────────────────────────────────────

# Node environment (development | production)
NODE_ENV=development

# Port the backend listens on (Nginx proxies /api → this port)
PORT=3001

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_secret

# ─── Optional ────────────────────────────────────────────────────────────────

# Anthropic API key — only needed for credit card PDF statement import.
# CSV imports from major banks (Chase, Citi, Capital One, BofA) are parsed
# locally for free. Only unknown CSV formats and PDF statements use Claude.
# Get your key at: https://console.anthropic.com
# Cost: ~$0.001–$0.01 per PDF import using claude-haiku-4-5 model
# ANTHROPIC_API_KEY=sk-ant-...
